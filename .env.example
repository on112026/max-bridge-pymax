# =====================================================================
# max-bridge-pymax — переменные окружения (этап 2, PyMax 2.2.0).
#
# Скопируйте в .env и заполните:
#   cp .env.example .env
#   $EDITOR .env
# =====================================================================

# --- Telegram bot ------------------------------------------------------
# Токен бота от @BotFather.
TELEGRAM_BOT_TOKEN=

# Список Telegram user_id, которым бот будет отвечать. Запятая без пробелов.
# Свой ID можно узнать у @userinfobot.
ALLOWED_TG_USER_IDS=123456789

# --- MAX (PyMax) -------------------------------------------------------
# Телефон в международном формате с +. Используется только для первичной
# SMS-авторизации. После первого успешного логина PyMax сохраняет сессию
# в CACHE_DIR и телефон/код больше не спрашиваются, пока вы не сделаете
# `make wipe-cache` или /reauth_sms в боте.
MAX_PHONE=+79000000000

# Где PyMax хранит свою сессию и sqlite-кэш. Внутри контейнера — том
# /app/cache (см. docker-compose.yaml).
CACHE_DIR=/app/cache

# --- Внутренний API (мост между ботом и max-процессом) ----------------
API_HOST=0.0.0.0
API_PORT=8000

# Длинный случайный ключ. Сгенерируйте: `make gen-key`
BRIDGE_API_KEY=

# --- Хранилище --------------------------------------------------------
# SQLite-БД (события, очереди отправки, статусы чатов).
DB_PATH=/data/bridge.db

# Куда складываются скачанные из MAX вложения перед отправкой в Telegram.
MEDIA_DIR=/data/media

# --- Логи -------------------------------------------------------------
# Глобальный уровень (применяется к нашим логгерам).
LOG_LEVEL=INFO

# Уровень только для логгера "pymax" (внутрибиблиотечный). По умолчанию
# приглушается до WARNING в shared/log_setup.py, чтобы не зашумлять
# рабочий лог msgpack-обменом.
PYMAX_LOG_LEVEL=INFO

# Задержка между реконнектами PyMax-клиента, сек.
PYMAX_RECONNECT_DELAY=2.0

# --- Форматирование (MAX → Telegram в топиках supergroup) -------------
# Упрощённое оформление сообщений из MAX в топиках супергруппы:
#   * без шапки "💬 чат / ↘️ автор · время" (топик уже несёт контекст);
#   * без inline-кнопок (автоэхо в топике и так работает, история чата
#     лежит прямо в нём, ID не нужен).
# В личке и в /history по-прежнему используется полный формат с шапкой
# и кнопками «Ответить / ID / История».
# Подтверждение доставки входящих — реакцией 📨, отправка в MAX — ✅
# через handlers/auth/topic_echo.py.
# По умолчанию OFF (старое поведение: шапка + inline-кнопки), чтобы
# включить упрощённый режим — выставьте в true.
COMPACT_TOPIC_MESSAGES=false

# --- Диагностика long-poll в MAX-процессе ------------------------------
# Управляет тем, что ``app.bridge`` пишет в лог при получении inbound-фреймов
# от PyMax. Используется для отлова источника событий реакций (MAX присылает
# их как opcode=135 NOTIF_CHAT, а не 155/156, как ожидает вендор).
#
#   ``off``   — вообще не логировать (прод-режим после диагностики).
#   ``react`` — по умолчанию: логировать только фреймы, похожие на реакции
#               (подстрока ``REACT`` в opcode или ``reaction`` в payload).
#   ``all``   — логировать вообще все inbound-фреймы (кроме PING).
#                payload обрезается до MAX_BRIDGE_RAW_LOG_MAX символов.
# Используется на время диагностики; после фикса оставить ``off`` или ``react``.
MAX_BRIDGE_RAW_LOG=react
MAX_BRIDGE_RAW_LOG_MAX=800
